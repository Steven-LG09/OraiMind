      "parameters": {
        "jsCode": "const original = $('Normalize Input').first().json.body;\nconst content = $input.first().json.choices[0].message.content;\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(content);\n} catch (error) {\n  parsed = {\n    error: \"Invalid JSON\",\n    raw: content\n  };\n}\n\nreturn [{\n  ...original,  // 👈 text, user\n  ...parsed     // 👈 intent, urgency, etc.\n}];"
