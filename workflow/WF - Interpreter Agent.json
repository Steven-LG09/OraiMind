        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an AI operations analyst. Return ONLY valid JSON without markdown,```json, backticks or explanations.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Analyze this request and extract:\\n- intent\\n- category (technical | billing | general | other)\\n- urgency (low | medium | high | critical)\\n- summary\\n- requires_action (true/false)\\n\\nReturn ONLY valid JSON in this format:\\n{\\n  \\\"intent\\\": \\\"string\\\",\\n  \\\"category\\\": \\\"string\\\",\\n  \\\"urgency\\\": \\\"string\\\",\\n  \\\"summary\\\": \\\"string\\\",\\n  \\\"requires_action\\\": true\\n}\\n\\nRequest: {{$json.text}}\"\n    }\n  ],\n  \"temperature\": 0.2\n}",
